{
    "name": "web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint src",
        "lint:report": "eslint --output-file eslint_report.json --format json src",
        "generate": "bunx openapi-typescript ../api/api.v1.openapi.yaml --output types/api.d.ts --root-types --properties-required-by-default=false --default-non-nullable=false && eslint --fix types/api.d.ts",
        "format": "prettier --write src"
    },
    "dependencies": {
        "@clerk/nextjs": "^7.3.5",
        "@clerk/ui": "^1.11.0",
        "@tabler/icons-react": "^3.44.0",
        "@tanstack/react-form": "^1.32.0",
        "@tanstack/react-form-nextjs": "^1.32.0",
        "@tanstack/react-pacer": "^0.22.1",
        "@tanstack/react-query": "^5.100.10",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "next": "^16.2.6",
        "next-themes": "^0.4.6",
        "openapi-fetch": "^0.17.0",
        "openapi-react-query": "^0.5.4",
        "radix-ui": "^1.4.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "shadcn": "^4.7.0",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "~9.39.4",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ],
    "engines": {
        "bun": ">=1.3.14"
    },
    "packageManager": "bun@1.3.14"
}
